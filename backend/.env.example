# Copy to .env (local) or set these in your host's Environment Variables.
# Use TEST keys first (sk_test_..., pk_test_...), then switch to live.

STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SIGNING_SECRET

# Shared secret your EDI middleware (or internal tool) sends in the
# x-dhi-secret header to authorize capture-on-ship. Make it long/random.
SHIP_CONFIRM_SECRET=change-me-to-a-long-random-string

# The exact origin of your website (for CORS). Example:
# https://www.digitalhealthinternational.com  (no trailing slash)
ALLOWED_ORIGIN=https://www.digitalhealthinternational.com
