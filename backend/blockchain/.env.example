# backend/blockchain/.env  — DEPLOY-TIME ONLY (local). Do NOT commit a real .env.
# Testnet only — never put a mainnet key with real value here.

# RPC endpoint (public default works; override with Alchemy/Infura free tier if rate-limited)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Private key of the deployer/minter wallet (TESTNET wallet only).
# Generate one, then fund it from a Base Sepolia faucet before deploying.
DEPLOYER_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Optional alternative testnet:
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology
