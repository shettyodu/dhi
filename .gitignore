# This repo is the deployable DHI site + Netlify payment functions only.
# The surrounding folder is a research/source dump, so we ALLOWLIST what to commit.

# 1) ignore everything at the top level by default
/*

# 2) re-include only the deployable pieces
!/.gitignore
!/netlify.toml
!/package.json
!/site/
!/backend/
!/WESCO_EDI_request_email.md
# AutoCommand workflow drop (separate Python service)
!/autocommand-workflow/

# 3) never commit secrets, dependencies, build output, or OS cruft
marketing/            # internal marketing/outreach docs — keep local, never publish
backend/node_modules/
backend/.env
# Smart-contract subproject: commit source only, never deps/build output/keys
backend/blockchain/node_modules/
backend/blockchain/artifacts/
backend/blockchain/cache/
backend/blockchain/.env
.env
.netlify/
.vercel/
**/.DS_Store
